<% if(success.length > 0){ %>

<script>

document.addEventListener("DOMContentLoaded", function(){

    Swal.fire({

        icon: "success",

        title: "Success",

        text: "<%= success[0] %>",

        timer: 2500,

        showConfirmButton: false

    });

});

</script>

<% } %>

<% if(error.length > 0){ %>

<script>

document.addEventListener("DOMContentLoaded", function(){

    Swal.fire({

        icon: "error",

        title: "Oops...",

        text: "<%= error[0] %>",

        confirmButtonColor: "#d33"

    });

});

</script>

<% } %>